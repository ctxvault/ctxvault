{
  "id": "policy_ctxvault_p0_default",
  "scope": {
    "kind": "project",
    "value": "ctxvault"
  },
  "name": "CtxVault P0 deterministic safeguards",
  "operation_rules": [
    {
      "operation": "memory_promotion",
      "requires_backup": true,
      "max_backup_age_hours": 24,
      "require_human_review": true,
      "applies_to_sensitivity": ["internal", "sensitive", "restricted"],
      "on_failure": "block"
    },
    {
      "operation": "prompt_patch_promotion",
      "requires_backup": true,
      "max_backup_age_hours": 24,
      "require_human_review": true,
      "applies_to_sensitivity": ["internal", "sensitive", "restricted"],
      "on_failure": "block"
    },
    {
      "operation": "workstream_promotion",
      "requires_backup": true,
      "max_backup_age_hours": 24,
      "require_human_review": true,
      "applies_to_sensitivity": ["internal", "sensitive", "restricted"],
      "on_failure": "block"
    },
    {
      "operation": "context_export",
      "requires_backup": true,
      "max_backup_age_hours": 24,
      "require_human_review": true,
      "applies_to_sensitivity": ["sensitive", "restricted"],
      "on_failure": "escalate"
    },
    {
      "operation": "destructive_redaction",
      "requires_backup": true,
      "max_backup_age_hours": 4,
      "require_human_review": true,
      "applies_to_sensitivity": ["sensitive", "restricted"],
      "on_failure": "rollback_required"
    },
    {
      "operation": "logical_purge_derived",
      "requires_backup": true,
      "max_backup_age_hours": 24,
      "require_human_review": true,
      "applies_to_sensitivity": ["public", "internal", "sensitive", "restricted"],
      "on_failure": "block"
    },
    {
      "operation": "model_external_send",
      "requires_backup": false,
      "max_backup_age_hours": null,
      "require_human_review": true,
      "applies_to_sensitivity": ["internal", "sensitive", "restricted"],
      "on_failure": "block"
    }
  ],
  "export_rules": [
    {
      "sensitivities": ["public", "internal"],
      "action": "allow",
      "redact_secret_refs": true,
      "require_human_review": false
    },
    {
      "sensitivities": ["sensitive"],
      "action": "redact",
      "redact_secret_refs": true,
      "require_human_review": true
    },
    {
      "sensitivities": ["restricted"],
      "action": "block",
      "redact_secret_refs": true,
      "require_human_review": true
    }
  ],
  "rollback_triggers": [
    "backup_receipt_missing",
    "backup_receipt_stale",
    "projection_corruption",
    "schema_migration_failure",
    "destructive_redaction_without_backup",
    "export_policy_violation"
  ],
  "secret_ref_schemes": [
    "secret",
    "credential",
    "keychain"
  ],
  "notes": "P0 contract: deterministic core remains usable without model services, but high-impact operations stay guarded.",
  "updated_at": "2026-04-19T09:35:00Z"
}
