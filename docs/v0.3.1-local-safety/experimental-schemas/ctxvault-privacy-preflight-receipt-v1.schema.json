{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ctxvault/experimental/ctxvault-privacy-preflight-receipt-v1.schema.json",
  "title": "CtxVault Privacy Preflight Receipt v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "contract_state",
    "receipt_id",
    "selection_ref",
    "selection_mode",
    "target_kind",
    "selected_slice_refs",
    "selected_slice_count",
    "source_refs",
    "decision",
    "highest_severity",
    "highest_sensitivity",
    "privacy_classes",
    "candidate_content_sha256",
    "redacted_content_sha256",
    "token_estimate",
    "projection_gate",
    "privacy_scan",
    "selected_slices",
    "created_at"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "enum": ["ctxvault.privacy-preflight-receipt/v1"]
    },
    "contract_state": {
      "type": "string",
      "enum": ["experimental"]
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^privacy_preflight_"
    },
    "selection_ref": {
      "type": "string",
      "pattern": "^context-selection://"
    },
    "selection_mode": {
      "type": "string",
      "enum": ["explicit_slice_refs"]
    },
    "target_kind": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": ["string", "null"]
    },
    "workstream_ref": {
      "type": ["string", "null"]
    },
    "selected_slice_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^slice://"
      }
    },
    "selected_slice_count": {
      "type": "integer",
      "minimum": 1
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "redact", "review", "block"]
    },
    "highest_severity": {
      "type": "string",
      "enum": ["none", "low", "medium", "high", "critical"]
    },
    "highest_sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "sensitive", "restricted"]
    },
    "privacy_classes": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidate_content_sha256": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "redacted_content_sha256": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "token_estimate": {
      "type": "integer",
      "minimum": 0
    },
    "projection_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_for_selected_slice_projection",
        "allowed_to_write",
        "blocking_decisions"
      ],
      "properties": {
        "required_for_selected_slice_projection": {
          "type": "boolean"
        },
        "allowed_to_write": {
          "type": "boolean"
        },
        "blocking_decisions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["block"]
          }
        }
      }
    },
    "privacy_scan": {
      "type": "object"
    },
    "selected_slices": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "created_at": {
      "type": "string"
    }
  }
}
