{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ctxvault/experimental/ctxvault-context-slice-v1.schema.json",
  "title": "CtxVault Context Slice",
  "description": "Experimental rebuildable read-model contract for deterministic local context slices. This is not canonical truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "slice_id",
    "slice_ref",
    "source_ref",
    "source_object_kind",
    "scope_kind",
    "scope_value",
    "workstream_ref",
    "slice_kind",
    "title",
    "heading_path",
    "line_start",
    "line_end",
    "byte_start",
    "byte_end",
    "content_sha256",
    "redacted_sha256",
    "privacy_class",
    "sensitivity",
    "redaction_state",
    "token_estimate",
    "updated_at",
    "redacted_preview",
    "source_content_sha256",
    "ranking_boost"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "enum": ["ctxvault.context-slice/v1"]
    },
    "slice_id": {
      "type": "string",
      "minLength": 8
    },
    "slice_ref": {
      "type": "string",
      "pattern": "^slice://.+#.+/.+"
    },
    "source_ref": {
      "$ref": "#/$defs/Reference"
    },
    "source_object_kind": {
      "type": "string",
      "enum": [
        "knowledge_artifact",
        "turn",
        "episode",
        "compiled_workstream_state"
      ]
    },
    "scope_kind": {
      "type": ["string", "null"]
    },
    "scope_value": {
      "type": ["string", "null"]
    },
    "workstream_ref": {
      "anyOf": [
        { "$ref": "#/$defs/Reference" },
        { "type": "null" }
      ]
    },
    "slice_kind": {
      "type": "string",
      "enum": [
        "markdown_heading_section",
        "markdown_paragraph",
        "markdown_list_block",
        "markdown_code_block",
        "session_turn",
        "session_episode",
        "memory_statement",
        "workstream_decision",
        "workstream_constraint",
        "workstream_open_question",
        "compiled_state_summary"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "heading_path": {
      "type": ["string", "null"]
    },
    "line_start": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "line_end": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "byte_start": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "byte_end": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "content_sha256": {
      "$ref": "#/$defs/Sha256"
    },
    "redacted_sha256": {
      "anyOf": [
        { "$ref": "#/$defs/Sha256" },
        { "type": "null" }
      ]
    },
    "privacy_class": {
      "type": "string",
      "enum": [
        "searchable_plain",
        "searchable_redacted",
        "metadata_only",
        "withheld"
      ]
    },
    "sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "sensitive", "restricted"]
    },
    "redaction_state": {
      "type": "string",
      "enum": ["none", "partial", "fully_redacted", "withheld"]
    },
    "token_estimate": {
      "type": "integer",
      "minimum": 0
    },
    "updated_at": {
      "$ref": "#/$defs/Timestamp"
    },
    "redacted_preview": {
      "type": "string"
    },
    "source_content_sha256": {
      "$ref": "#/$defs/Sha256"
    },
    "ranking_boost": {
      "type": "number"
    }
  },
  "$defs": {
    "Reference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9+.-]*://.+"
    },
    "Sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
