{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ctxvault/schemas/ctxvault-controls-v0.schema.json",
  "title": "CtxVault Control Objects",
  "description": "Schema for backup, rollback, and protection-policy objects in ctxvault v0.",
  "oneOf": [
    { "$ref": "#/$defs/BackupCheckReceipt" },
    { "$ref": "#/$defs/ProtectionPolicy" },
    { "$ref": "#/$defs/RollbackDecision" },
    { "$ref": "#/$defs/ProjectionReceipt" }
  ],
  "$defs": {
    "ScopeKind": {
      "type": "string",
      "enum": [
        "global",
        "user",
        "workspace",
        "project",
        "thread",
        "task",
        "turn"
      ]
    },
    "Scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "$ref": "#/$defs/ScopeKind" },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "Reference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9+.-]*://.+"
    },
    "ReferenceArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/Reference" },
      "default": []
    },
    "StringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "SensitivityLevel": {
      "type": "string",
      "enum": ["public", "internal", "sensitive", "restricted"]
    },
    "SensitivityArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/SensitivityLevel" },
      "default": []
    },
    "OperationKind": {
      "type": "string",
      "enum": [
        "memory_promotion",
        "prompt_patch_promotion",
        "workstream_promotion",
        "knowledge_export",
        "context_export",
        "index_rebuild",
        "destructive_redaction",
        "redaction_reversal",
        "logical_purge_derived",
        "model_external_send"
      ]
    },
    "BackupStatus": {
      "type": "string",
      "enum": ["ok", "stale", "missing", "failed"]
    },
    "BackupMode": {
      "type": "string",
      "enum": ["preflight", "scheduled", "manual", "migration_guard"]
    },
    "FailureAction": {
      "type": "string",
      "enum": ["block", "escalate", "rollback_required"]
    },
    "ExportAction": {
      "type": "string",
      "enum": ["allow", "redact", "review", "block"]
    },
    "ProjectionKind": {
      "type": "string",
      "enum": ["harness", "human-readable", "first-party-surface"]
    },
    "MergePolicy": {
      "type": "string",
      "enum": ["replace", "merge", "append", "skip"]
    },
    "ProjectionOutputStatus": {
      "type": "string",
      "enum": ["written", "updated", "skipped", "blocked"]
    },
    "ProjectionReviewState": {
      "type": "string",
      "enum": ["generated", "pending-reconciliation", "reviewed"]
    },
    "RollbackTriggerKind": {
      "type": "string",
      "enum": [
        "backup_receipt_missing",
        "backup_receipt_stale",
        "redaction_policy_violation",
        "export_policy_violation",
        "projection_corruption",
        "schema_migration_failure",
        "destructive_redaction_without_backup",
        "durable_write_validation_failure"
      ]
    },
    "RollbackTriggerList": {
      "type": "array",
      "items": { "$ref": "#/$defs/RollbackTriggerKind" },
      "default": []
    },
    "RollbackSeverity": {
      "type": "string",
      "enum": ["warning", "rollback_recommended", "rollback_required"]
    },
    "RollbackAction": {
      "type": "string",
      "enum": [
        "pause_writes",
        "restore_last_valid_backup",
        "rebuild_projection",
        "require_human_review"
      ]
    },
    "RollbackState": {
      "type": "string",
      "enum": ["declared", "validated", "executed", "dismissed"]
    },
    "OperationRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "requires_backup",
        "require_human_review",
        "applies_to_sensitivity",
        "on_failure"
      ],
      "properties": {
        "operation": { "$ref": "#/$defs/OperationKind" },
        "requires_backup": { "type": "boolean" },
        "max_backup_age_hours": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "require_human_review": { "type": "boolean" },
        "applies_to_sensitivity": { "$ref": "#/$defs/SensitivityArray" },
        "on_failure": { "$ref": "#/$defs/FailureAction" }
      }
    },
    "ExportRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sensitivities",
        "action",
        "redact_secret_refs",
        "require_human_review"
      ],
      "properties": {
        "sensitivities": { "$ref": "#/$defs/SensitivityArray" },
        "action": { "$ref": "#/$defs/ExportAction" },
        "redact_secret_refs": { "type": "boolean" },
        "require_human_review": { "type": "boolean" }
      }
    },
    "BackupCheckReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scope",
        "checked_at",
        "status",
        "mode",
        "protected_refs",
        "artifact_refs",
        "restore_tested",
        "max_age_hours"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^backup_" },
        "scope": { "$ref": "#/$defs/Scope" },
        "checked_at": { "$ref": "#/$defs/Timestamp" },
        "status": { "$ref": "#/$defs/BackupStatus" },
        "mode": { "$ref": "#/$defs/BackupMode" },
        "protected_refs": { "$ref": "#/$defs/ReferenceArray" },
        "artifact_refs": { "$ref": "#/$defs/ReferenceArray" },
        "recovery_point_at": {
          "anyOf": [
            { "$ref": "#/$defs/Timestamp" },
            { "type": "null" }
          ]
        },
        "restore_tested": { "type": "boolean" },
        "max_age_hours": { "type": "integer", "minimum": 1 },
        "notes": { "type": ["string", "null"] }
      }
    },
    "ProtectionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scope",
        "name",
        "operation_rules",
        "export_rules",
        "rollback_triggers",
        "secret_ref_schemes",
        "updated_at"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^policy_" },
        "scope": { "$ref": "#/$defs/Scope" },
        "name": { "type": "string", "minLength": 1 },
        "operation_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/OperationRule" }
        },
        "export_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/ExportRule" }
        },
        "rollback_triggers": { "$ref": "#/$defs/RollbackTriggerList" },
        "secret_ref_schemes": { "$ref": "#/$defs/StringArray" },
        "notes": { "type": ["string", "null"] },
        "updated_at": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "RollbackDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "triggered_at",
        "trigger",
        "severity",
        "affected_refs",
        "action",
        "state"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^rollback_" },
        "triggered_at": { "$ref": "#/$defs/Timestamp" },
        "trigger": { "$ref": "#/$defs/RollbackTriggerKind" },
        "severity": { "$ref": "#/$defs/RollbackSeverity" },
        "affected_refs": { "$ref": "#/$defs/ReferenceArray" },
        "backup_receipt_ref": {
          "anyOf": [
            { "$ref": "#/$defs/Reference" },
            { "type": "null" }
          ]
        },
        "action": { "$ref": "#/$defs/RollbackAction" },
        "state": { "$ref": "#/$defs/RollbackState" },
        "notes": { "type": ["string", "null"] }
      }
    },
    "ProjectionReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "receipt_id",
        "created_at",
        "projection_id",
        "projection_kind",
        "target_kind",
        "target_path",
        "source_refs",
        "source_object_kinds",
        "scope",
        "plugin_id",
        "plugin_version",
        "render_policy",
        "merge_policy",
        "output_sha256",
        "output_bytes",
        "output_status",
        "policy_decision",
        "review_state",
        "warnings"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "ctxvault.projection-receipt/v1"
        },
        "receipt_id": { "type": "string", "pattern": "^projection_" },
        "created_at": { "$ref": "#/$defs/Timestamp" },
        "projection_id": { "type": "string", "minLength": 1 },
        "projection_kind": { "$ref": "#/$defs/ProjectionKind" },
        "target_kind": { "type": "string", "minLength": 1 },
        "target_path": { "type": "string", "minLength": 1 },
        "source_refs": { "$ref": "#/$defs/ReferenceArray" },
        "source_object_kinds": { "$ref": "#/$defs/StringArray" },
        "scope": { "$ref": "#/$defs/Scope" },
        "plugin_id": { "type": "string", "minLength": 1 },
        "plugin_version": { "type": "string", "minLength": 1 },
        "render_policy": { "type": "string", "minLength": 1 },
        "merge_policy": { "$ref": "#/$defs/MergePolicy" },
        "output_sha256": { "type": "string", "minLength": 1 },
        "output_bytes": { "type": "integer", "minimum": 0 },
        "output_status": { "$ref": "#/$defs/ProjectionOutputStatus" },
        "policy_decision": { "$ref": "#/$defs/ExportAction" },
        "review_state": { "$ref": "#/$defs/ProjectionReviewState" },
        "warnings": { "$ref": "#/$defs/StringArray" },
        "selected_slice_refs": { "$ref": "#/$defs/ReferenceArray" },
        "privacy_preflight": { "type": ["object", "null"] }
      }
    }
  }
}
