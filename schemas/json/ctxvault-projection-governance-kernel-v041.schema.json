{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ctxvault/schemas/ctxvault-projection-governance-kernel-v041.schema.json",
  "title": "CtxVault v0.4.1 Projection Governance Kernel",
  "description": "Minimal v0.4.1 object model schema for reviewed context handoff. This is a schema explanation and fixture contract, not a stable external API or runtime-control protocol.",
  "oneOf": [
    { "$ref": "#/$defs/ProjectionGovernanceKernelProjection" },
    { "$ref": "#/$defs/ProjectionGovernanceKernelReceipt" }
  ],
  "$defs": {
    "Reference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9+.-]*://.+"
    },
    "StringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "CandidateIdArray": {
      "type": "array",
      "items": { "type": "string", "pattern": "^cand_" },
      "default": []
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "ScopeKind": {
      "type": "string",
      "enum": [
        "global",
        "user",
        "workspace",
        "project",
        "thread",
        "task",
        "turn",
        "workstream"
      ]
    },
    "Scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "$ref": "#/$defs/ScopeKind" },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "SourceEvidenceKind": {
      "type": "string",
      "enum": [
        "file",
        "transcript",
        "note",
        "demo_vault_entry",
        "release_artifact",
        "fixture"
      ]
    },
    "SourceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "path_or_ref"],
      "properties": {
        "id": { "type": "string", "pattern": "^src_" },
        "kind": { "$ref": "#/$defs/SourceEvidenceKind" },
        "path_or_ref": { "$ref": "#/$defs/Reference" },
        "digest": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "captured_at": {
          "anyOf": [
            { "$ref": "#/$defs/Timestamp" },
            { "type": "null" }
          ]
        }
      }
    },
    "CandidateContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_ids",
        "summary_or_excerpt",
        "scope",
        "status"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^cand_" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^src_" },
          "default": []
        },
        "summary_or_excerpt": { "type": "string", "minLength": 1 },
        "scope": { "$ref": "#/$defs/Scope" },
        "confidence": {
          "anyOf": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "type": "null" }
          ]
        },
        "status": {
          "type": "string",
          "enum": ["candidate"]
        }
      }
    },
    "ReviewDecisionKind": {
      "type": "string",
      "enum": ["selected", "omitted", "blocked"]
    },
    "ReviewDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "decision", "reason", "scope"],
      "properties": {
        "candidate_id": { "type": "string", "pattern": "^cand_" },
        "decision": { "$ref": "#/$defs/ReviewDecisionKind" },
        "reason": { "type": "string", "minLength": 1 },
        "scope": { "$ref": "#/$defs/Scope" },
        "reviewer": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "reviewed_at": {
          "anyOf": [
            { "$ref": "#/$defs/Timestamp" },
            { "type": "null" }
          ]
        }
      }
    },
    "TargetSurface": {
      "type": "string",
      "enum": [
        "agents_md",
        "claude_md",
        "codex",
        "claude_code",
        "chatgpt_projects",
        "generic_project_folder",
        "workstream_brief",
        "handoff_packet"
      ]
    },
    "Projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "target_surface",
        "included_candidate_ids",
        "scope",
        "created_at"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^proj_" },
        "target_surface": { "$ref": "#/$defs/TargetSurface" },
        "included_candidate_ids": { "$ref": "#/$defs/CandidateIdArray" },
        "scope": { "$ref": "#/$defs/Scope" },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "HandoffPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "projection_id",
        "target_surface",
        "artifact_ref",
        "runtime_control_claim"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^handoff_" },
        "projection_id": { "type": "string", "pattern": "^proj_" },
        "target_surface": { "$ref": "#/$defs/TargetSurface" },
        "artifact_ref": { "$ref": "#/$defs/Reference" },
        "runtime_control_claim": {
          "type": "string",
          "enum": ["not_claimed"]
        }
      }
    },
    "ReceiptStates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected",
        "omitted",
        "blocked",
        "written",
        "not_done"
      ],
      "properties": {
        "selected": { "$ref": "#/$defs/CandidateIdArray" },
        "omitted": { "$ref": "#/$defs/CandidateIdArray" },
        "blocked": { "$ref": "#/$defs/CandidateIdArray" },
        "written": { "$ref": "#/$defs/StringArray" },
        "not_done": { "$ref": "#/$defs/StringArray" }
      }
    },
    "Receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "projection_id",
        "states",
        "generated_at"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^rcpt_" },
        "projection_id": { "type": "string", "pattern": "^proj_" },
        "states": { "$ref": "#/$defs/ReceiptStates" },
        "generated_at": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "ProjectionGovernanceKernelProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "source_evidence",
        "candidate_context",
        "review_decisions",
        "projection",
        "handoff_packet"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": ["ctxvault.projection-governance-kernel.projection/v1"]
        },
        "source_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceEvidence" }
        },
        "candidate_context": {
          "type": "array",
          "items": { "$ref": "#/$defs/CandidateContext" }
        },
        "review_decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/ReviewDecision" }
        },
        "projection": { "$ref": "#/$defs/Projection" },
        "handoff_packet": { "$ref": "#/$defs/HandoffPacket" }
      }
    },
    "ProjectionGovernanceKernelReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "receipt"],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": ["ctxvault.projection-governance-kernel.receipt/v1"]
        },
        "receipt": { "$ref": "#/$defs/Receipt" }
      }
    }
  }
}
